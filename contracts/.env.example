# Deployer wallet private key (same as backend). Get from MetaMask: Account details → Show private key. See docs/WALLET_AND_KEYS.md.
# Use the wallet that has test NEON from https://neonfaucet.org (add Neon Devnet to MetaMask first).
PRIVATE_KEY=your_64_char_hex_with_or_without_0x

# Neon EVM Devnet RPC (default: https://devnet.neonevm.org)
NEON_RPC_URL=https://devnet.neonevm.org

# Optional: for mainnet
# NEON_MAINNET_RPC_URL=https://mainnet.neonevm.org
