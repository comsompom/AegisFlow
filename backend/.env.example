# Neon EVM (Solana) RPC
NEON_RPC_URL=https://devnet.neonevm.org

# Deployer/treasury private key (hex, with or without 0x) — used to sign txs
PRIVATE_KEY=your_hex_private_key

# Contract addresses (from contracts/deployed.json after deploy)
COMPLIANCE_REGISTRY_ADDRESS=0x...
AEGISFLOW_VAULT_ADDRESS=0x...

# OpenAI (optional — for AI treasury agent)
OPENAI_API_KEY=sk-...

# Travel Rule threshold (USD equivalent or units)
TRAVEL_RULE_THRESHOLD=1000

# KYT API (optional — mock if not set)
# KYT_API_URL=
# KYT_API_KEY=

# Database (optional — SQLite by default for audit/travel rule)
# DATABASE_URL=sqlite+aiosqlite:///./aegisflow.db
