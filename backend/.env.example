# Solana (required — hackathon: build on Solana)
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PROGRAM_ID=   # From: anchor keys list (after anchor build in contracts-solana)
# Signer for whitelist/limits/vault_withdraw (path to keypair JSON or base58 secret)
SOLANA_KEYPAIR_PATH=  # e.g. ~/.config/solana/id.json
# SOLANA_PRIVATE_KEY=  # alternative: base58 or base64 secret key

# OpenAI (optional — for AI treasury agent)
OPENAI_API_KEY=sk-...

# Travel Rule threshold (lamports or units)
TRAVEL_RULE_THRESHOLD=1000

# KYT API (optional)
# KYT_API_URL=
# KYT_API_KEY=

# SQLite (required). Audit and Travel Rule data.
DATABASE_URL=sqlite:///./aegisflow.db
