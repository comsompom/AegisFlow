# Neon EVM (Solana) RPC
NEON_RPC_URL=https://devnet.neonevm.org

# Same wallet as contracts deployer. Get from MetaMask: Account details → Show private key. See docs/WALLET_AND_KEYS.md.
PRIVATE_KEY=your_64_char_hex_with_or_without_0x

# Contract addresses (from contracts/deployed.json after deploy)
COMPLIANCE_REGISTRY_ADDRESS=0x...
AEGISFLOW_VAULT_ADDRESS=0x...

# OpenAI (optional — for AI treasury agent)
OPENAI_API_KEY=sk-...

# Travel Rule threshold (USD equivalent or units)
TRAVEL_RULE_THRESHOLD=1000

# KYT API (optional — mock if not set)
# KYT_API_URL=
# KYT_API_KEY=

# SQLite database (required). Audit log and Travel Rule data are stored here. Default: aegisflow.db in backend dir.
DATABASE_URL=sqlite:///./aegisflow.db
